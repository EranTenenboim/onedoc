SERVER_PORT=8000
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
RETRY_DELAY=1.0
MAX_RETRIES=3
WORKER_IDLE_TIMEOUT=30
LOG_FILE=logs/interactions.log

# Abuse prevention
ENFORCE_MEDICAL_ONLY=true
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

# Optional: override static assets path
# STATIC_DIR=static

# Required when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Required when LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
